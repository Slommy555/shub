# Copy this file to .env.local and fill in your Supabase project values.
# Both values are safe to expose in the client bundle — Row Level Security
# enforces access. NEVER put your service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Web Push (VAPID) public key — safe to expose. Generate with:
#   npx web-push generate-vapid-keys
# Store the matching PRIVATE key as a Supabase secret (VAPID_PRIVATE_KEY), never here.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
