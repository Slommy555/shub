# Expo public env — copy to .env.local. Use the SAME values as the web app
# (web/.env.local): EXPO_PUBLIC_SUPABASE_URL = VITE_SUPABASE_URL, and
# EXPO_PUBLIC_SUPABASE_ANON_KEY = VITE_SUPABASE_ANON_KEY.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Single-user "username" gate. Typing EXPO_PUBLIC_DEV_USERNAME on the login
# screen signs into this Supabase account (email+password) behind the scenes,
# so no password is ever typed. The account must exist in Supabase Auth with
# this exact email+password (set it once in the dashboard).
EXPO_PUBLIC_DEV_USERNAME=Slommy Dev
EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=
