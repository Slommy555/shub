# Expo public env — copy to .env.local. Use the SAME values as the web app
# (web/.env.local): EXPO_PUBLIC_SUPABASE_URL = VITE_SUPABASE_URL, and
# EXPO_PUBLIC_SUPABASE_ANON_KEY = VITE_SUPABASE_ANON_KEY.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The app logs in with email + password (same as the web PWA). Optional: set
# EXPO_PUBLIC_DEV_EMAIL to prefill the email field on the login screen — the
# password is always typed, so changing your password never needs an env edit.
EXPO_PUBLIC_DEV_EMAIL=
